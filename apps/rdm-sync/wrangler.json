{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "live-rail-info-rdm-sync",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8789,
    "inspector_port": 9233
  },
  "workers_dev": false,
  "preview_urls": false,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "zawa",
      "database_id": "05f7f789-f869-45c3-a1fb-d9fe896800d5",
      "preview_database_id": "f0f89855-89c2-463c-a3eb-42d2d47ab39c",
      "migrations_table": "d1_migrations",
      "migrations_dir": "../../packages/db/src/migrations"
    }
  ],
  "queues": {
    "producers": [
      {
        "queue": "rail-events",
        "binding": "RAIL_EVENTS_QUEUE"
      }
    ]
  },
  "triggers": {
    "crons": [
      "*/5 * * * *",
      "1,6,11,16,21,26,31,36,41,46,51,56 * * * *",
      "4,9,14,19,24,29,34,39,44,49,54,59 * * * *",
      "7,22,37,52 * * * *",
      "43 * * * *",
      "17 2 * * *",
      "13 * * * *"
    ]
  },
  "vars": {
    "RDM_REFERENCE_STATION_LIST_URL": "https://api1.raildata.org.uk/1010-reference-data1_0/LDBSVWS/api/ref/20211101/GetStationList/{currentVersion}",
    "RDM_REFERENCE_TOC_LIST_URL": "https://api1.raildata.org.uk/1010-reference-data1_0/LDBSVWS/api/ref/20211101/GetTOCList/{currentVersion}",
    "RDM_REFERENCE_REASON_CODE_LIST_URL": "https://api1.raildata.org.uk/1010-reference-data1_0/LDBSVWS/api/ref/20211101/GetReasonCodeList",
    "RDM_REFERENCE_LOADING_CATEGORY_URL": "https://api1.raildata.org.uk/1010-reference-data1_0/LDBSVWS/api/ref/20211101/GetLoadingCategoryData/{currentVersion}",
    "RDM_REFERENCE_SOURCE_INSTANCE_NAMES_URL": "https://api1.raildata.org.uk/1010-reference-data1_0/LDBSVWS/api/ref/20211101/GetSourceInstanceNames",
    "RDM_STATIONS_TOC_URL": "https://api1.raildata.org.uk/1010-knowlegebase-stations-xml-feed1_1/4.0/stations-{TOC}.xml",
    "RDM_STATION_BY_CRS_URL": "https://api1.raildata.org.uk/1010-knowlegebase-stations-xml-feed1_1/4.0/station-{CRS}.xml",
    "RDM_DISRUPTION_LIST_URL": "https://api1.raildata.org.uk/1010-disruption-list1_0/LDBSVWS/api/20220120/GetDisruptionList/{CRSList}",
    "RDM_NSI_URL": "https://api1.raildata.org.uk/1010-knowlegebase-national-service-indicator-xml-feed2_0/4.0/serviceindicators.xml",
    "RDM_NSI_TOC_URL": "https://api1.raildata.org.uk/1010-knowlegebase-national-service-indicator-xml-feed2_0/4.0/serviceindicators-{TOC}.xml",
    "RDM_INCIDENTS_URL": "https://api1.raildata.org.uk/1010-knowlegebase-incidents-xml-feed1_0/incidents.xml",
    "RDM_STATION_REFRESH_BATCH_SIZE": "100",
    "RDM_STATION_REFRESH_STALE_MINUTES": "30",
    "RDM_STATION_PROFILE_BATCH_SIZE": "25",
    "RDM_STATION_DISRUPTION_BATCH_SIZE": "20",
    "RDM_INCIDENT_BATCH_SIZE": "100",
    "RDM_QUEUE_SEND_TIMEOUT_MS": "20000",
    "RDM_SYNC_JOB_TIMEOUT_MS": "240000",
    "RDM_ONTOLOGY_QUALITY_TIMEOUT_MS": "120000"
  },
  "secrets": {
    "required": [
      "RDM_REFERENCE_DATA_API_KEY",
      "RDM_STATIONS_API_KEY",
      "RDM_DISRUPTIONS_API_KEY",
      "RDM_NSI_API_KEY",
      "RDM_INCIDENTS_API_KEY"
    ]
  }
}
