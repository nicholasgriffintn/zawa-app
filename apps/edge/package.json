{
  "name": "@zawa/edge",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "db:migrate:local": "wrangler d1 migrations apply zawa --local --persist-to ../../.wrangler/state",
    "db:migrate:preview": "wrangler d1 migrations apply zawa --remote --preview",
    "db:migrate:prod": "wrangler d1 migrations apply zawa --remote",
    "dev": "vite dev",
    "deploy": "wrangler deploy",
    "build": "vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"I don't need tests, I don't want tests. Do not add them.\" && exit 0"
  },
  "dependencies": {
    "@zawa/db": "workspace:*",
    "@zawa/domain": "workspace:*",
    "@zawa/ontology": "workspace:*",
    "@zawa/rdm": "workspace:*",
    "@zawa/realtime": "workspace:*",
    "@zawa/shared": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "catalog:",
    "playwright": "catalog:",
    "sass": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
